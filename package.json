{
  "name": "@quigleybits/claude-skills",
  "version": "0.2.0",
  "description": "Custom Claude Code skills: recon, debrief, and more",
  "author": "quigleyBits",
  "license": "MIT",
  "keywords": [
    "claude-code",
    "skills",
    "slash-commands",
    "ai-agents",
    "recon",
    "project-reconnaissance",
    "debrief",
    "session-management"
  ],
  "files": [
    "skills/recon/",
    "skills/debrief/",
    "scripts/link-skills.mjs",
    ".claude-plugin/",
    "README.md",
    "CHANGELOG.md",
    "LICENSE"
  ],
  "scripts": {
    "eval": "node scripts/eval-skills.mjs",
    "test:node": "node --test tests/security-hardening.test.mjs",
    "test:python": "python -m unittest discover -s tests -p \"test_*.py\" -v",
    "test": "npm run test:node && npm run test:python",
    "validate": "node scripts/validate-skills.mjs",
    "security": "node skills/debrief/scan-secrets.mjs --all",
    "check": "npm run validate && npm test && npm run security",
    "stats": "node scripts/skill-stats.mjs",
    "link": "node scripts/link-skills.mjs",
    "unlink": "node scripts/link-skills.mjs --unlink",
    "create": "node scripts/create-skill.mjs",
    "postinstall": "node scripts/link-skills.mjs --quiet",
    "preuninstall": "node scripts/link-skills.mjs --unlink --quiet"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Quigleybits/custom_claude_skills.git"
  }
}
